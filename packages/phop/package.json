{
  "name": "@peterddod/phop",
  "version": "1.1.14",
  "description": "Peer-to-peer state management for React using WebRTC. Share and sync state across browsers in real time — no backend required.",
  "keywords": [
    "react",
    "p2p",
    "webrtc",
    "peer-to-peer"
  ],
  "license": "MIT",
  "author": "Peter Dodd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peterddod/phop.git"
  },
  "homepage": "https://github.com/peterddod/phop#readme",
  "bugs": {
    "url": "https://github.com/peterddod/phop/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --sourcemap --watch"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.1.9",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
