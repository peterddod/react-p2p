{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/bump-version.mjs ${nextRelease.version} && echo ${nextRelease.version} > .release-version",
        "publishCmd": "cd packages/phop && npm publish --access public --userconfig ../../.npmrc",
        "successCmd": "git add CHANGELOG.md packages/phop/package.json packages/signalling-server/package.json && git commit -m \"chore(release): ${nextRelease.version} [skip ci]\" && git push origin HEAD:main"
      }
    ],
    "@semantic-release/github"
  ]
}
