{
  "name": "react-p2p-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "P2P state management for React - monorepo",
  "license": "MIT",
  "author": "Peter Dodd",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --parallel dev:server dev:example dev:lib",
    "dev:server": "bun --filter=signalling-server dev",
    "dev:example": "bun --filter=example dev",
    "dev:lib": "bun --filter=react-p2p dev",
    "build": "bun run build --filter='./packages/*'",
    "build:lib": "bun --filter=react-p2p run build",
    "build:server": "bun --filter=signalling-server run build",
    "build:example": "bun --filter=example run build",
    "start:server": "bun --filter=signalling-server start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "test": "echo \"No tests specified\""
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "react-refresh": "^0.18.0",
    "semantic-release": "^25.0.3"
  }
}
